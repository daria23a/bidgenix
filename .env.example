# ---- BidGenix environment ----
# Everything here is OPTIONAL. With nothing set the app runs in local demo mode
# (JSON answer library, no auth, no billing). Fill these in for production.

# Public site URL (used for auth + Stripe redirects)
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- OpenAI (drafting + embeddings) ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# ---- Supabase (Postgres + pgvector, auth) ----
# From Supabase project settings -> API
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ---- Stripe (billing) ----
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
# Price IDs for each plan (create products/prices in Stripe dashboard)
STRIPE_PRICE_STARTER=
STRIPE_PRICE_PRO=
STRIPE_PRICE_SCALE=
